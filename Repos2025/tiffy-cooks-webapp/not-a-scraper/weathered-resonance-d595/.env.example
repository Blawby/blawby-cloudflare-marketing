# Cloudflare Workers Environment Variables
#
# IMPORTANT: This project uses Wrangler Secrets, NOT .env files for production!
#
# To set secrets, use:
#   wrangler secret put CRAWL_SECRET
#   wrangler secret put GOOGLE_API_KEY
#
# The .env file is only for local development reference.
# Never commit actual secrets to version control!

# Admin secret for creating API keys and accessing admin endpoints
CRAWL_SECRET=qGqIoWhf8SetlDGJOfU1aoClcwRm5hICigiDm8Yr7bg=

# Google Custom Search API key for crawling lawyer data
GOOGLE_API_KEY=your_google_api_key_here

# Example API usage:
# curl -H "Authorization: Bearer qGqIoWhf8SetlDGJOfU1aoClcwRm5hICigiDm8Yr7bg=" \
#      https://search.blawby.com/api-keys

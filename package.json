{
  "name": "compass",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20.9.0 <25"
  },
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "check:legacy-paths": "node scripts/check-legacy-paths.mjs",
    "check:links": "node scripts/check-internal-links.mjs",
    "check:seo": "node scripts/check-seo.mjs",
    "check:sitemap": "node scripts/check-sitemap.mjs",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "r2:upload-content": "node scripts/upload-content-to-r2.mjs",
    "test": "pnpm run typecheck && pnpm run lint && pnpm run format:check",
    "test:worker": "node scripts/test-worker.js",
    "test:chatbot": "node scripts/test-chatbot.js",
    "test:prod": "TEST_URL=https://compass-ts.paulchrisluke.workers.dev node scripts/test-worker.js",
    "test:chatbot:prod": "TEST_URL=https://compass-ts.paulchrisluke.workers.dev node scripts/test-chatbot.js"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.2",
    "@heroicons/react": "^2.2.0",
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^16.2.3",
    "@shikijs/colorized-brackets": "^3.4.0",
    "@tailwindcss/postcss": "^4.1.7",
    "clsx": "^2.1.1",
    "geist": "^1.3.1",
    "input-otp": "^1.4.2",
    "marked": "^15.0.12",
    "next": "^16.2.4",
    "node-webvtt": "^1.9.4",
    "postcss": "^8.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "remark-gfm": "^4.0.1",
    "resend": "^4.5.1",
    "shiki": "^3.4.0",
    "tailwindcss": "^4.1.13",
    "use-debounce": "^10.0.4",
    "vanilla-cookieconsent": "^3.1.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250529.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mdx": "^2.0.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^16.5.0",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.3",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.1",
    "p-limit": "^4.0.0",
    "prettier": "^3.5.3",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "remark": "^15.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^10.0.2",
    "remark-stringify": "^11.0.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.5",
    "typescript": "^5",
    "unified": "^10.1.2",
    "unist-util-visit": "^4.1.2",
    "wrangler": "^4.38.0"
  },
  "type": "module"
}
